---
export interface Job {
	n2: string;
	period: string;
	current: boolean;
	role: string;
	company: string;
	location: string;
	bullets: string[];
	stack: string[];
	logo: string;
	site?: string;
}

interface Props {
	job: Job;
	activeLabel: string;
}

const { job, activeLabel } = Astro.props;
---

<div class="grid grid-cols-[clamp(64px,16vw,108px)_1fr] gap-[clamp(14px,3vw,28px)] border-t border-border py-6">
	<div>
		<div class="text-[22px] leading-none font-bold text-idx">{job.n2}</div>
		<div class="mt-2.5 font-mono text-[11.5px] leading-normal font-medium text-muted2">{job.period}</div>
		{
			job.current && (
				<div class="mt-2.5 inline-flex items-center gap-1.5 font-mono text-[10px] leading-none font-semibold tracking-[0.08em] text-green">
					<span class="size-1.5 rounded-full bg-green" />
					{activeLabel}
				</div>
			)
		}
	</div>
	<div class="flex items-start gap-4">
		<img src={job.logo}
			class="flex size-11.5 flex-none items-center justify-center rounded-[10px] border border-border2 bg-surface font-mono text-lg leading-none font-semibold text-muted2"
			aria-hidden="true"
		>
		<div class="min-w-0 flex-1">
			<div class="flex flex-wrap items-baseline gap-2.5">
				<h3 class="text-[clamp(17px,2.5vw,19px)] leading-[1.3] font-semibold text-text">{job.role}</h3>
				{job.site && (
					<a class="text-sm leading-none font-medium text-accent hover:underline" href={job.site} target="_blank" rel="noopener">{job.company} ↗</a>
				)}
				<span class="ml-auto font-mono text-[11.5px] leading-none font-medium text-faint">{job.location}</span>
			</div>
			<div class="mt-3 flex flex-col gap-1.5">
				{
					job.bullets.map((b) => (
						<div class="flex gap-2.5 text-[clamp(13.5px,2vw,14.5px)] leading-[1.6] text-muted">
							<span class="mt-px text-accent">—</span>
							<span>{b}</span>
						</div>
					))
				}
			</div>
			<div class="mt-3.5 flex flex-wrap items-center gap-[7px]">
				{
					job.stack.map((t) => (
						<span class="rounded-[5px] border border-border2 px-[9px] py-[5px] font-mono text-[11px] leading-none font-medium text-muted2">{t}</span>
					))
				}
				
			</div>
		</div>
	</div>
</div>
